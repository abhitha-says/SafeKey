# ─── SafeKey Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Resend (Email OTP Delivery) ─────────────────────────────────────────────
# SafeKey sends OTP emails directly via Resend HTTP API (bypasses Supabase SMTP).
# Get your API key from: https://resend.com > API Keys
#
# SETUP:
#   1. Create an account at https://resend.com
#   2. Add & verify the domain opscores.in at Resend > Domains
#   3. Create an API key at Resend > API Keys
#   4. Paste it below
EXPO_PUBLIC_RESEND_API_KEY=re_your_resend_api_key_here
